{
  "name": "tvzalupa-screenshoter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:backend": "tsx watch src/main.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p tsconfig.build.json",
    "build:frontend": "vue-tsc -p frontend/tsconfig.json --noEmit && vite build --config frontend/vite.config.ts",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"frontend/src/**/*.{ts,vue,css}\" \"*.json\" \"*.md\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@primeuix/themes": "^1.2.5",
    "@types/express": "^5.0.3",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "eslint": "^9.17.0",
    "pinia": "^3.0.3",
    "playwright": "^1.60.0",
    "prettier": "^3.4.2",
    "primevue": "^4.3.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1",
    "vue-tsc": "^2.2.10"
  }
}
